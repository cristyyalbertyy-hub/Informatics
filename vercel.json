{
  "buildCommand": "npm run build",
  "outputDirectory": ".",
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/((?!styles\\.css|config\\.public\\.js|firebase-client\\.js|auth-gate\\.js|main\\.js|app\\.js|progress-client\\.js|playback-progress\\.js|favicon\\.svg|Public/).*)",
      "destination": "/index.html"
    }
  ]
}
